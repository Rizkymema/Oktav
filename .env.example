# Root path ke repo Hermes Agent lokal yang dipakai sebagai sumber skill referensi.
# Kosongkan untuk memakai fallback lokal default dari developer saat ini.
HERMES_REFERENCE_ROOT=D:\Project Apk-Web\hermesagentai\hermes-agent-main

# Provider AI yang dipakai untuk model dan generasi artifact.
OPENAI_API_KEY=
VIDEO_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
BLOB_STORE_ID=

# Genvid embedded video engine configuration.
GENVID_ENABLED=false
GENVID_API_URL=http://127.0.0.1:8000
GENVID_ROOT=
GENVID_AUTO_START=false
GENVID_START_COMMAND=uv run python api/app.py --host 127.0.0.1 --port 8000
GENVID_HEALTH_TIMEOUT_MS=5000
GENVID_POLL_INTERVAL_MS=2500
GENVID_POLL_TIMEOUT_MS=300000
GENVID_FRAME_TEMPLATE=1080x1920/static_default.html
GENVID_SCENE_COUNT=5
GENVID_LLM_BASE_URL=
GENVID_LLM_MODEL=
GENVID_FALLBACK_MODE=legacy_ffmpeg
 
